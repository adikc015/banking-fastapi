# App security
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=mysql+aiomysql://root:password@127.0.0.1:3306/banking_app

# Google OAuth (optional)
OAUTH_GOOGLE_CLIENT_ID=
